{
  "name": "agentbridge",
  "version": "0.1.0",
  "description": "OpenClaw-first AgentBridge CLI for installing heartbeat-based agent task coordination.",
  "private": false,
  "type": "module",
  "bin": {
    "agentbridge": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "templates"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "tsc -p tsconfig.json",
    "pack:dry-run": "corepack pnpm pack --dry-run",
    "start": "node dist/index.js"
  },
  "keywords": [
    "agentbridge",
    "openclaw",
    "ai-agents",
    "multi-agent",
    "agent-ops",
    "agent-coordination",
    "cli"
  ],
  "homepage": "https://github.com/Vann-Dev/AgentBridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vann-Dev/AgentBridge.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/Vann-Dev/AgentBridge/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {}
}
