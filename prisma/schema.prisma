generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  todo
  inprogress
  done
  blocked
}

model Company {
  id              String @id @default(uuid()) @db.Uuid
  name            String
  description     String
  bearerTokenHash String @unique

  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents      Agent[]
  projects    Project[]

  @@index([userId])
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companies Company[]
}

model Project {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String

  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([companyId])
}

model Task {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  job            String
  note           String?
  status         Status    @default(todo)
  blockingReason String?

  projectId       String  @db.Uuid
  assignedAgentId String  @db.Uuid
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigned        Agent          @relation(fields: [assignedAgentId], references: [id], onDelete: Restrict)
  readMarkers     TaskReadMarker[]

  @@index([projectId])
  @@index([assignedAgentId])
}

model Agent {
  id          String @id @default(uuid()) @db.Uuid
  AgentId     String @unique
  name        String
  description String
  position    String

  tasks       Task[]
  readMarkers TaskReadMarker[]
  companyId   String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model TaskReadMarker {
  id     String   @id @default(uuid()) @db.Uuid
  status Status
  readAt DateTime @default(now())

  taskId  String @db.Uuid
  agentId String @db.Uuid
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([taskId, agentId, status])
  @@index([agentId])
}
