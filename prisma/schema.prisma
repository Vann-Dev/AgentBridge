generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  todo
  inprogress
  done
  blocked
}

model Company {
  id              String @id @default(uuid()) @db.Uuid
  name            String
  description     String
  bearerTokenHash String @unique

  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents      Agent[]
  projects    Project[]
  auditLogs   AuditLog[]

  @@index([userId])
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companies Company[]
}

model LoginThrottle {
  id             String    @id @default(uuid()) @db.Uuid
  username       String
  ipAddress      String
  failedAttempts Int       @default(0)
  lastFailedAt   DateTime
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([username, ipAddress])
  @@index([ipAddress, lastFailedAt])
  @@index([lockedUntil])
}

model Project {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String

  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks     Task[]
  agents    ProjectAgent[]

  @@index([companyId])
}

model Task {
  id                String    @id @default(uuid()) @db.Uuid
  name              String
  job               String
  note              String?
  summaryUpdatedAt  DateTime?
  status            Status    @default(todo)
  blockingReason    String?
  archivedAt        DateTime?
  taskUpdatedAt     DateTime  @default(now())
  taskUpdatedById   String?   @db.Uuid
  taskUpdatedByName String?
  taskUpdatedByType String    @default("system")

  projectId       String @db.Uuid
  assignedAgentId String @db.Uuid
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigned        Agent   @relation(fields: [assignedAgentId], references: [id], onDelete: Restrict)

  readMarkers           TaskReadMarker[]
  blockedByDependencies TaskDependency[] @relation("BlockedTaskDependencies")
  unblocksDependencies  TaskDependency[] @relation("DependencyTaskDependencies")

  @@index([projectId])
  @@index([assignedAgentId])
  @@index([archivedAt])
}

model Agent {
  id          String @id @default(uuid()) @db.Uuid
  AgentId     String @unique
  name        String
  description String
  position    String

  tasks       Task[]
  readMarkers TaskReadMarker[]
  projects    ProjectAgent[]
  companyId   String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model ProjectAgent {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())

  projectId String  @db.Uuid
  agentId   String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([projectId, agentId])
  @@index([agentId])
}

model TaskDependency {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())

  blockedTaskId    String @db.Uuid
  dependencyTaskId String @db.Uuid
  blockedTask      Task   @relation("BlockedTaskDependencies", fields: [blockedTaskId], references: [id], onDelete: Cascade)
  dependencyTask   Task   @relation("DependencyTaskDependencies", fields: [dependencyTaskId], references: [id], onDelete: Cascade)

  @@unique([blockedTaskId, dependencyTaskId])
  @@index([dependencyTaskId])
}

model TaskReadMarker {
  id     String   @id @default(uuid()) @db.Uuid
  status Status
  readAt DateTime @default(now())

  taskId  String @db.Uuid
  agentId String @db.Uuid
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([taskId, agentId, status])
  @@index([agentId])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  targetType String
  targetId   String?  @db.Uuid
  targetName String?
  details    String?
  actorType  String
  actorId    String?  @db.Uuid
  actorName  String?
  createdAt  DateTime @default(now())

  companyId String  @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([targetType, targetId])
}
